body{
font-family:Arial;
margin:0;
background:#f5f5f5;
}

.header{
display:flex;
justify-content:space-between;
align-items:center;
padding:20px;
background:white;
box-shadow:0 2px 5px rgba(0,0,0,0.1);
}

.logo{
font-size:24px;
font-weight:bold;
}

.nav a{
margin:10px;
text-decoration:none;
color:black;
}

.hero{
background:black;
color:white;
text-align:center;
padding:100px;
}

.hero p{
background:red;
display:inline-block;
padding:10px 20px;
margin-top:10px;
}

.flash{
padding:40px;
text-align:center;
}

.product-container{
display:flex;
justify-content:center;
flex-wrap:wrap;
gap:20px;
}

.product{
background:white;
width:220px;
padding:15px;
border-radius:10px;
text-align:center;
}

.product img{
width:100%;
}

.product button{
background:red;
color:white;
border:none;
padding:8px 12px;
cursor:pointer;
}

.category{
padding:40px;
text-align:center;
}

.category-box{
display:flex;
justify-content:center;
flex-wrap:wrap;
gap:20px;
}

.cat{
background:white;
padding:20px;
width:120px;
border-radius:10px;
}

.best{
padding:40px;
text-align:center;
}

.promo{
background:black;
color:white;
text-align:center;
padding:80px;
}

.promo button{
background:green;
padding:10px 20px;
border:none;
color:white;
}

.explore{
padding:40px;
text-align:center;
}

.footer{
background:black;
color:white;
padding:40px;
}

.footer-container{
display:flex;
justify-content:space-around;
flex-wrap:wrap;
}

.copy{
text-align:center;
margin-top:20px;
}
